# Frontend SPA Vite servi par Apache (alwaysdata).

# 1) Fallback SPA : toute route inconnue renvoie index.html.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# 2) Compression gzip.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain \
    application/javascript application/json image/svg+xml
</IfModule>

# 3) Cache : assets hashés immuables 1 an, index.html jamais mis en cache.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|png|jpe?g|gif|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "(index\.html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
